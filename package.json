{
  "name": "geodynamo",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "report": "bun run index.ts",
    "report:ci": "bun run index.ts --output geodynamo-report.md --json-output geodynamo-snapshot.json --field-output geodynamo-field-map.json --plan-output geodynamo-action-plan.json --history-output geodynamo-history.json",
    "build:dashboard": "bun run dashboard/build.ts",
    "check": "bun tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@openai/codex-sdk": "^0.142.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
